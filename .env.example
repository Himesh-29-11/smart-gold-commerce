APP_NAME="N & H Trust"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_IN
APP_TIMEZONE=Asia/Kolkata

APP_MAINTENANCE_DRIVER=file
BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=smart_gold
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=false
SESSION_SAME_SITE=lax

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
CACHE_STORE=database

MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="trustedgolds@gmail.com"
MAIL_FROM_NAME="${APP_NAME}"

COMMERCE_CURRENCY=INR
FREE_DELIVERY_THRESHOLD=50000
DELIVERY_CHARGE=0
SUPPORT_EMAIL=trustedgolds@gmail.com
SUPPORT_PHONE="+91 95123 48850"
INVOICE_PREFIX=SGC

# razorpay or stripe
PAYMENT_PROVIDER=razorpay
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
STRIPE_KEY=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=

# Browser key restricted to approved domains. Leave blank for timeline-only tracking.
GOOGLE_MAPS_API_KEY=

# Optional normalized HTTPS handoff for one contracted loan provider.
# Leave blank to retain requests for manual operations review.
LOAN_PROVIDER_PRIMARY_SLUG=
LOAN_PROVIDER_PRIMARY_ENDPOINT=
LOAN_PROVIDER_PRIMARY_TOKEN=
LOAN_PROVIDER_TIMEOUT=10

# Use only a licensed/authorized data provider. `database` serves cached/demo rows only.
GOLD_PRICE_PROVIDER=database
GOLD_PRICE_API_URL=
# Optional historical URL template; {date} and {currency} are replaced at runtime.
GOLD_PRICE_HISTORY_API_URL=
GOLD_PRICE_HISTORY_DATE_FORMAT=Y-m-d
GOLD_PRICE_API_KEY=
# header, bearer, query, or none
GOLD_PRICE_API_AUTH_MODE=header
GOLD_PRICE_API_KEY_HEADER=X-API-Key
GOLD_PRICE_API_KEY_QUERY=api_key
GOLD_PRICE_API_KEY_PREFIX=
GOLD_PRICE_CURRENCY=INR
GOLD_PRICE_API_UNIT=gram
GOLD_PRICE_API_TIMEOUT=10
GOLD_PRICE_22K_PATH=rates.22K
GOLD_PRICE_24K_PATH=rates.24K
GOLD_PRICE_22K_CHANGE_PATH=changes.22K
GOLD_PRICE_24K_CHANGE_PATH=changes.24K
GOLD_PRICE_TIMESTAMP_PATH=timestamp
# Historical response paths may differ; leave equal to latest paths when the schemas match.
GOLD_PRICE_HISTORY_22K_PATH=rates.22K
GOLD_PRICE_HISTORY_24K_PATH=rates.24K
GOLD_PRICE_HISTORY_22K_CHANGE_PATH=changes.22K
GOLD_PRICE_HISTORY_24K_CHANGE_PATH=changes.24K
GOLD_PRICE_HISTORY_TIMESTAMP_PATH=timestamp
GOLD_PRICE_STALE_MINUTES=30
GOLD_PRICE_BLOCK_STALE_CHECKOUT=true
# Keep false unless you explicitly need to test checkout with labelled demo values locally.
GOLD_PRICE_ALLOW_DEMO_CHECKOUT=false
GOLD_PRICE_DASHBOARD_POLL_SECONDS=60

VITE_APP_NAME="${APP_NAME}"
