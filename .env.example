APP_NAME="Aurum Trust"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_IN
APP_TIMEZONE=Asia/Kolkata

APP_MAINTENANCE_DRIVER=file
BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=smart_gold
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=false
SESSION_SAME_SITE=lax

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
CACHE_STORE=database

MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@aurumtrust.example"
MAIL_FROM_NAME="${APP_NAME}"

COMMERCE_CURRENCY=INR
FREE_DELIVERY_THRESHOLD=50000
DELIVERY_CHARGE=499
SUPPORT_EMAIL=trustedgolds@gmail.com
SUPPORT_PHONE="+91 95123 48850"
INVOICE_PREFIX=SGC

# razorpay or stripe
PAYMENT_PROVIDER=razorpay
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
STRIPE_KEY=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=

# Optional normalized HTTPS handoff for one contracted loan provider.
# Leave blank to retain requests for manual operations review.
LOAN_PROVIDER_PRIMARY_SLUG=
LOAN_PROVIDER_PRIMARY_ENDPOINT=
LOAN_PROVIDER_PRIMARY_TOKEN=
LOAN_PROVIDER_TIMEOUT=10

# Use only a licensed/authorized data provider. `database` serves the latest cached rate.
GOLD_PRICE_PROVIDER=database
GOLD_PRICE_API_URL=
GOLD_PRICE_API_KEY=
GOLD_PRICE_API_KEY_HEADER=X-API-Key
GOLD_PRICE_CURRENCY=INR
GOLD_PRICE_API_UNIT=gram
GOLD_PRICE_API_TIMEOUT=10
GOLD_PRICE_22K_PATH=rates.22K
GOLD_PRICE_24K_PATH=rates.24K
GOLD_PRICE_22K_CHANGE_PATH=changes.22K
GOLD_PRICE_24K_CHANGE_PATH=changes.24K
GOLD_PRICE_TIMESTAMP_PATH=timestamp
GOLD_PRICE_STALE_MINUTES=90
GOLD_PRICE_BLOCK_STALE_CHECKOUT=true

VITE_APP_NAME="${APP_NAME}"
